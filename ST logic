(******** Power ON logic **********)

TON_1(IN:=true,PT:=t#3s);
TON_1_ET:=TON_1.ET;

R_TRIG_1(CLK:=TON_1.Q);

if R_TRIG_1.Q then;
   x_Main_Axis_Enable := true;
	x_Index_Axis_Enable := true;
	x_BothDriveEnable := true;		
end_if;

(******** Drive Status Read Logic **********)

TON_DriveStatusEn(IN:=not x_Enable_RS,PT:=t#1s);
t_DriveStatusEn:=TON_DriveStatusEn.ET;

if TON_DriveStatusEn.Q then
	x_Enable_RS := true;
end_if;

TON_DriveStatusDis(IN:=x_Enable_RS,PT:=t#1s);
t_DriveStatusDis:=TON_DriveStatusDis.ET;

if TON_DriveStatusDis.Q then
	x_Enable_RS := false;
end_if;

(******** Drive Temperature Read Logic **********)

if not x_trig then
	x_trig := true;
else
	x_trig := false;
end_if;

(******** Drive Fault HMI Display Logic **********)

if x_Errorstop_RS_Main then
	x_Main_Drive_Fault := true;
else
	x_Main_Drive_Fault := false;
end_if;

if x_Errorstop_RS_Index then
	x_Index_Drive_Fault := true;
else
	x_Index_Drive_Fault := false;
end_if;

(******** Power ON logic After Drive Fault Reset **********)

IF _Axis_1_TMPL.bError AND x_BothDriveEnable THEN
	(*x_Main_Axis_Enable := false;*)
	x_Main_Drive_Fault := true;
	QX_Buzzer2 := true;
else
	x_Main_Drive_Fault := false;
	QX_Buzzer2 := false;
end_if;

R_TRIG_MainDrivePowerEn(CLK:=TP_DriveReset.Q);

if R_TRIG_MainDrivePowerEn.Q and x_BothDriveEnable then
	x_Main_Axis_Enable := false;
end_if;

F_TRIG_MainDrivePowerEn(CLK:=TP_DriveReset.Q);

if F_TRIG_MainDrivePowerEn.Q and x_BothDriveEnable then
   x_Main_Axis_Enable := true;
end_if;
 
IF _Axis_2_TMPL.bError AND x_BothDriveEnable THEN
	(*x_Index_Axis_Enable := false;*)
	x_Index_Drive_Fault := true;
	QX_Buzzer2 := true;
else
	x_Index_Drive_Fault := false;
	QX_Buzzer2 := false;
end_if;

R_TRIG_IndexDrivePowerEn(CLK:=TP_DriveReset.Q);

if R_TRIG_IndexDrivePowerEn.Q and x_BothDriveEnable then
	x_Index_Axis_Enable := false;
end_if;

F_TRIG_IndexDrivePowerEn(CLK:=TP_DriveReset.Q);

if F_TRIG_IndexDrivePowerEn.Q and x_BothDriveEnable then
	x_Index_Axis_Enable := true;
end_if;

(********* Machine Ready conditions ***********)
if x_Main_Power_OK and x_Index_Power_OK and IX_Emg_Stop then;
   x_MachineReady := true;
else;
   x_MachineReady := false;
	x_AutoCycle_On := false;
	x_AutoSelected := false;
   x_ManualSelected := false;
end_if;

(******* Select Mode operations **************)
(* i_op_mode :=     0; Machine not ready *)
(* i_op_mode := > 100; Manual mode operations *)
(* i_op_mode := > 300; Auto mode - Homing operations *)
(* i_op_mode := > 500; Auto Clamp Mode Operations *)
(* i_op_mode := > 600; Auto Flexi Mode Operations *)
(* i_op_mode := > 700; Auto Stacker Mode Operations *)

if not x_MachineReady then;
 	i_op_mode := 0;
end_if;

if (IX_Auto_Manual_SW and not x_AutoSelected and x_MachineReady) then
	i_op_mode := 300;
	x_AutoSelected := true;
	x_ManualSelected := false;
end_if;

if (not IX_Auto_Manual_SW and not x_ManualSelected and x_MachineReady) then 
	i_op_mode := 100;
	x_AutoSelected := false;
	x_ManualSelected := true;
end_if;

(******************** Mode Selection  ********************)

if x_Clamp_Mode_HMI and not x_Clamp_Mode and not x_AutoCycle_On then
   x_Clamp_Mode := true;
	x_Stacker_Mode := false;
	x_Flexi_Mode := false;
	x_InitIndexing_over := false;
end_if;

if x_Flexi_Mode_HMI and not x_Flexi_Mode and not x_AutoCycle_On then
   x_Clamp_Mode := false;
	x_Stacker_Mode := false;
	x_Flexi_Mode := true;
	x_InitIndexing_over := false;
end_if;

if x_Stacker_Mode_HMI and not x_Stacker_Mode and not x_AutoCycle_On then
   x_Clamp_Mode := false;
	x_Stacker_Mode := true;
	x_Flexi_Mode := false;
	x_InitIndexing_over := false;
end_if;

(************* Auto - Manual Flag Set Reset  *******************)

IF x_ManualSelected OR _Axis_1_TMPL.bError OR _Axis_2_TMPL.bError THEN
   x_HomingDone := false;
	x_InitIndexing_over := false;
	x_StartIndexDLY := false;
	x_MotorStartDLY := false;
	x_MotorStartStckrDly := false;
	x_PlugDownDLY := false;
	x_FormingDly := false;
	x_VaccumDly := false;
	x_EjectionDlyTime := false;
	x_ScrapWDlyTime := false;
	x_LidEjectionDlyTime := false;
	x_HomingAtStop := false;
	x_CuttingPosOver := false;
	x_MainPosStartFlexi := false;
	x_ParkingPositionStart := false;
	x_AutoCycle_On := false;
	x_Cycle_Time := false;
	i_IndexAct_Cnt:= 0;
	(*x_MainPosStart := false;*)
	(*x_MainPosStartStckr := false;*)
	(*x_IndexStart := false;*)
	(*x_AutoSelected := false;*)
end_if;

(*R_TRIG_AutoManualRst(CLK:=x_Drive_Reset_HMI);

if R_TRIG_AutoManualRst.Q then
	x_ManualSelected := false;
	x_AutoSelected := false;
end_if;*)

(************* Auto - Manual Flag Set Reset  *******************)

TP_DriveReset(IN:=x_Drive_Reset_HMI,PT:=t#50ms);

if TP_DriveReset.Q then
	x_MainDriveReset := true;
	x_IndexDriveReset := true;
	x_ManualSelected := false;
	x_AutoSelected := false;
else
	x_MainDriveReset := false;
	x_IndexDriveReset := false;
end_if;

(************* Heater operation in Auto-Manual Mode ************)
if ((x_ManualSelected and x_MachineReady) or 
   (x_AutoSelected and x_MachineReady and (*x_InitIndexing_over*)x_AutoCycle_On)) then
	 QX_Heater := true;
else;
	 QX_Heater := false;
end_if;

(************* Manual Mode Jogging Operation ************)

(*rl_SetDegreeHMI:=real#360.0;*)
(*rl_CountsPerDeg:=real#3640.888; *) (* (20:1 GR * 65536) = 360 deg *)

rl_CountsPerDeg:=REAL#3549.866;  (* (19.5:1 GR * 65536) = 360 deg * Main Motor)*)

(*rl_CountsPerDeg:=real#3243.08; *) (* (17.8:1 GR * 65536) = 360 deg *)

(*rl_CountsPerDeg:=real#3513.34; *)(* (19.2:1 GR * 65536) = 360 deg * Main Motor 2)*)

(*rl_SetDistHMI  := real#300.0;*)
rl_CountsPerMM := REAL#1128.82;  (* (7:1 GR * 65536) = 406.4 mm *) (* 32 Teeth, 0.5 inch pitch, 129.57 PCD* Index Motor)*)

(*rl_SetClampPos := real#167.0;*)

rl_Index_Length := int_to_real(i_Index_Length);  

(*di_IndexDistance := real_to_dint(rl_CountsPerMM * rl_Index_Length);*)

(*xxxxxxxxxxxxxxxxxxxxxxxxxx*) 

Case (i_op_mode) of

100:
	if not IX_Auto_Manual_SW and x_MachineReady then;
			i_op_mode := 110;
	end_if;
	
110:
   (********** Main Motor Jog Operation *********)
   
	if IX_Jog_Fwd or IX_Jog_Rev or x_Jog_Fwd_HMI or x_Jog_Rev_HMI then
		x_Jog_Start := true;
		ud_Jog_speed := udint#1092; (*2185 Inc = 200 RPM*) (*1092 Inc = 100 RPM*)
	if IX_Jog_Fwd or x_Jog_Fwd_HMI then
		  i_Jog_Direction := 1;
	else;
		  i_Jog_Direction := 0;	 
	end_if;
	  x_HomingDone := false;
	end_if;
	if x_Jog_Start and not IX_Jog_Fwd and not IX_Jog_Rev and not x_Jog_Fwd_HMI and not x_Jog_Rev_HMI then
		i_op_mode := 120;
	end_if;			

   (********** Index Motor Jog Operation *********)
	if IX_Index_PB or x_Index_Jog_Fwd_HMI or x_Index_Jog_Rev_HMI then
		x_Index_Jog_Start := true;
		ud_Index_Jog_speed := dint_to_udint((int_to_dint(i_Index_JogSpeed) * dint#65536) / dint#6000); 
	if IX_Index_PB or x_Index_Jog_Fwd_HMI then
		i_Index_Jog_Direction := 1;
	else;
		i_Index_Jog_Direction := 0;
	end_if;
   	(* x_HomingDone := false;*)
	end_if;
	if x_Index_Jog_Start and not IX_Index_PB and not x_Index_Jog_Fwd_HMI and not x_Index_Jog_Rev_HMI then
		i_op_mode := 160;
	end_if;

	(********** Plug Up Down Operation *********)

	if IX_Plug_Down and not IX_Plug_Up then
		QX_Plug_UpDown := true;
	end_if;

	if IX_Plug_Up and not IX_Plug_Down then
		QX_Plug_UpDown := false;
	end_if;

	x_PiercingHeater_OnOff := x_PiercingHeater_OnOff;

120:
		x_Jog_Start := false;
		ud_Jog_speed := udint#0;
		i_op_mode := 130;
	
130:
	if not x_Jog_Start and not x_Jog_ok then
		x_Jog_Start := true;
		i_op_mode := 140;
	end_if;

140:
	if x_Jog_Start and x_Jog_ok then
		x_Jog_Start := false;
		i_op_mode := 150;
	end_if;

150:
	if not x_Jog_Start and not x_Jog_ok then
		i_op_mode := 110;
	end_if;

160:
		x_Index_Jog_Start := false;
		ud_Index_Jog_speed := udint#0;
		i_op_mode := 170;
	
170:
	if not x_Index_Jog_Start and not x_Index_Jog_ok then
		x_Index_Jog_Start := true;
		i_op_mode := 180;
	end_if;

180:
	if x_Index_Jog_Start and x_Index_Jog_ok then
		x_Index_Jog_Start := false;
		i_op_mode := 190;
	end_if;

190:
	if not x_Index_Jog_Start and not x_Index_Jog_ok then
		i_op_mode := 110;
	end_if;	

	
(************* Auto Mode Homing Operation ************)							

300:
	if x_HomingDone then
	(*i_op_mode := 500;
	end_if;*)

	if x_Clamp_Mode then
	   i_op_mode := 500;
	end_if;

	if x_Flexi_Mode then
		i_op_mode := 600;
	end_if;

	if x_Stacker_Mode then
		i_op_mode := 700;
	end_if;
	end_if;

	if ((IX_Home_PB or x_HomeStart_HMI or TON_Home_CycleStop.Q) and not x_HomingDone)then
		x_MainHomeStart := true;
		x_HomingAtStop := false;
		x_Init_ClampPosOver := false;
		x_CuttingPosOver := false;
		x_ParkingPosOver := false;
		x_ParkingPositionStart := false;
		x_MotorStartDLY := false;
		x_MainPosStartStckr := false;
		x_MainPosCompleteStckr := false; 
		x_CuttingPositionStart := false;
		x_MainPosStartFlexi := false;
		x_StartIndexDLY := false;
		x_InitIndexing_over := false;
		x_IndexComplete := false;
		x_IndexLengthComplete := false;
		x_MainPosComplete:= false;
		x_PlugDownDLY := false; 
		x_Cycle_Start_Dly := false;
		i_IndexAct_Cnt := int#0;	
		i_op_mode := 310;
	end_if;
	
	x_PiercingHeater_OnOff := x_PiercingHeater_OnOff;	
	
310:
	if x_MainHomeStart and x_Main_HomingDone then
		x_MainHomeStart := false;
		x_HomingDone := false;
		(*x_Init_ClampPosOver := false;
		x_CuttingPosOver := false;
		x_ParkingPositionStart := false;*)
		(*x_InitIndexing_over := false;*)
		i_op_mode := 320;
	end_if;	
	
320:
	x_HomingDone := true;

	if x_Clamp_Mode then
	   i_op_mode := 500;
	end_if;

	if x_Flexi_Mode then
		i_op_mode := 600;
	end_if;

	if x_Stacker_Mode then
		i_op_mode := 700;
	end_if;

(************* Auto Mode Operation (Clamp Mode) ************)

500:
	if ((IX_Cycle_Start or x_Cycle_Start_HMI) and not x_InitIndexing_over(*and(IX_Home_LS and IX_Plug_LS)*)) then
	   x_HomingDone := false;
		x_MotorStartDLY := false;
		x_Cycle_Start_Dly := true;
		x_AutoCycle_On := true;
		x_Cycle_Time := true;
		(*x_Init_Index_Start := true;*)
		(*i_IndexAct_Cnt:= 0;*)
		(*x_InitIndexing_over := false;*)	
		i_op_mode := 510;
	end_if;

	if ((IX_Cycle_Start or x_Cycle_Start_HMI) and x_InitIndexing_over(*and(IX_Home_LS and IX_Plug_LS)*)) then
		x_HomingDone := false;
		x_MotorStartDLY := false;
		x_StartIndexDLY := true;
		x_AutoCycle_On := true;
		x_Cycle_Time := true;
		(*x_Cycle_Start_Dly := true;*)	
		(*x_Init_Index_Start := true;*)
		(*i_IndexAct_Cnt:= 0;*)
		(*x_InitIndexing_over := false;*)
   end_if;

	(*if x_AutoCycle_On and TON_CycleStartDly.Q then	
		x_StartIndexDLY := true;
	end_if;*)

	if x_IndexOver and x_AutoCycle_On then
		i_op_mode := 530;
   end_if;

	if x_Flexi_Mode then
		i_op_mode := 600;
	end_if;

	if x_Stacker_Mode then
		i_op_mode := 700;
	end_if;

	x_PiercingHeater_OnOff := x_PiercingHeater_OnOff;

510:
	if TON_CycleStartDly.Q then
		x_StartIndexDLY := true;
		di_IndexDistance := real_to_dint(rl_CountsPerMM * rl_Index_Length);
		ud_Index_AutoSpeed := dint_to_udint((int_to_dint(i_Index_AutoSpeed) * dint#65536) / dint#60000); 
      (*ud_Index_AutoSpeed := int_to_udint(i_Index_AutoSpeed);*)
		i_op_mode := 520;
	end_if;

520:
	if x_IndexOver then
		x_IndexStart := false;
		x_StartIndexDLY := false;
		i_IndexAct_Cnt := i_IndexAct_Cnt + 1;
	end_if;

	if i_IndexAct_Cnt = i_IndexSet_Cnt then 
		x_InitIndexing_over := true;
		x_IndexLengthComplete := true;
	   i_op_mode := 530;
	  else;
		i_op_mode := 510;
	end_if;

530:

	ud_Main_Speed := dint_to_udint((int_to_dint(i_Main_AutoSpeed) * dint#65536) / dint#60000);

	if not x_Init_ClampPosOver then
	  	x_MotorStartDLY := true;
		rl_PrevClampPos := rl_SetClampPos;
		rl_NewClampPos := real#0.0;
		di_Main_distance := real_to_dint(rl_SetClampPos * rl_CountsPerDeg); (*first clamp position*)
      (*ud_Main_Speed := dint_to_udint((int_to_dint(i_Main_AutoSpeed) * dint#65536) / dint#6000);*)
		i_op_mode := 540;
	end_if;

	if x_Init_ClampPosOver and rl_PrevClampPos <> rl_SetClampPos and not x_NewClampPos then
		rl_NewClampPos := (rl_SetClampPos - rl_PrevClampPos);
		(*diff_pos := rl_NewClampPos;*)
		rl_PrevClampPos := rl_SetClampPos;
		x_NewClampPos := true;
	end_if;

	if not IX_Plug_LS and x_Init_ClampPosOver and x_NextCycleStart then
	   (*di_Main_distance := real_To_dint((real#360.0 + rl_NewClampPos) * rl_CountsPerDeg);*)
		(*rl_NewClampPos := real#0.0;*)
    (*if x_NewClampPos then
		new_pos := di_Main_distance;
		end_if;*)
		x_NewClampPos := false;
		x_Cycle_Time := true;
		x_NextCycleStart := false;
		i_op_mode := 540;
	 end_if;

	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;		
		i_op_mode := 300;	
	end_if;
	
	x_PiercingHeater_OnOff := x_PiercingHeater_OnOff;
		
540:	  		
	IF (NOT IX_Index_LS AND x_MainPosStart (*and (x_IndexComplete or x_IndexLengthComplete) and x_MainPosComplete) (*and (x_IndexOver or not x_NextCycleStart )*)*)) THEN
		x_PlugDownDLY := true;
   	i_op_mode := 550;
	end_if;

	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;	
		i_op_mode := 300;
	end_if;			

	(*x_NextCycleStart := false;*)

550:
	if T_PlugDownDly.Q and (x_IndexComplete or x_IndexLengthComplete) and x_MainPosComplete then
		x_IndexLengthComplete := false;
		x_IndexComplete := false;
		x_MainPosComplete:= false;
		x_FormingDly := true;
		x_VaccumDly := true;	
		(*	x_NextCycleStart := false; *)
		x_Init_ClampPosOver := true;
		di_Main_distance := real_To_dint((real#360.0 + rl_NewClampPos) * rl_CountsPerDeg);
		rl_NewClampPos := real#0.0;
		i_op_mode := 560;
	end_if;
	
	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;	
		i_op_mode := 300;
	end_if;		

560:
	if T_PlugDownDly.Q and not TP_PlugDownTime.Q and IX_Plug_LS then
		x_MotorStartDLY := true;
		x_EjectionDlyTime := true;
		x_ScrapWDlyTime := true;
		x_UnwinderDly := true;
		x_PlugDownDLY := false;
		i_op_mode := 570;
	end_if;
	
	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then 
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;	
		i_op_mode := 300;
	end_if;		

570:

	ud_Index_AutoSpeed := dint_to_udint((int_to_dint(i_Index_AutoSpeed) * dint#65536) / dint#60000);
	di_IndexDistance := real_to_dint(rl_CountsPerMM * rl_Index_Length);

	if T_EjectionDlyTime.Q then
		x_StartIndexDLY := true; 
		x_EjectionDlyTime := false;
		x_NextCycleStart := true;
		x_Cycle_Time := false;
		i_op_mode := 530;
	end_if;

	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;		
		i_op_mode := 300;
	end_if;
			
(*end_case;*)

(************* Auto Mode Operation (Flexi Mode) **************)

600:

	rl_SetClampPosChanged := rl_SetClampPos;

	rl_SetCuttingPosChanged := rl_SetCuttingPos;

	rl_SetParkingPosChanged := rl_SetParkingPos;

   if ((IX_Cycle_Start or x_Cycle_Start_HMI) and not x_InitIndexing_over(*and(IX_Home_LS and IX_Plug_LS)*)) then
	   x_HomingDone := false;
		x_MotorStartDLY := false;
		x_Cycle_Start_Dly := true;
		x_AutoCycle_On := true;
		x_Cycle_Time := true;
		(*x_Init_Index_Start := true;*)
		(*i_IndexAct_Cnt:= 0;*)
		(*x_InitIndexing_over := false;*)
		i_op_mode := 610;
	end_if;

	if ((IX_Cycle_Start or x_Cycle_Start_HMI) and x_InitIndexing_over(*and(IX_Home_LS and IX_Plug_LS)*)) then
		x_HomingDone := false;
		x_MotorStartDLY := false;
		x_StartIndexDLY := true;
		x_AutoCycle_On := true;
		x_Cycle_Time := true;
		(*x_Init_Index_Start := true;*)
		(*i_IndexAct_Cnt:= 0;*)
		(*x_InitIndexing_over := false;*)
   end_if;

	if x_IndexOver and x_AutoCycle_On then
		i_op_mode := 630;
   end_if;

	if x_Clamp_Mode then
		i_op_mode := 500;
	end_if;

	if x_Stacker_Mode then
		i_op_mode := 700;
	end_if;

	x_PiercingHeater_OnOff := x_PiercingHeater_OnOff;

610:
	if TON_CycleStartDly.Q then	
		x_StartIndexDLY := true;
		di_IndexDistance := real_to_dint(rl_CountsPerMM * rl_Index_Length);
		ud_Index_AutoSpeed := dint_to_udint((int_to_dint(i_Index_AutoSpeed) * dint#65536) / dint#60000);
      (*ud_Index_AutoSpeed := int_to_udint(i_Index_AutoSpeed);*)
		i_op_mode := 620;
	end_if;

620:
	if x_IndexOver then
		x_IndexStart := false;
		x_StartIndexDLY := false;
		i_IndexAct_Cnt := i_IndexAct_Cnt + 1;
	end_if;

	if i_IndexAct_Cnt = i_IndexSet_Cnt then 
		x_InitIndexing_over := true;
		x_IndexLengthComplete := true;
	   i_op_mode := 630;
	  else;
		i_op_mode := 610;
	end_if;

630:
	
	ud_Main_Speed := dint_to_udint((int_to_dint(i_Main_AutoSpeed) * dint#65536) / dint#60000);
		
	rl_SetClampPosChanged := rl_SetClampPos + rl_NewClampPos ;
	rl_NewClampPos := real#0.0;

	rl_SetCuttingPosChanged := rl_SetCuttingPos + rl_NewCuttingPos;
	rl_NewCuttingPos := real#0.0;

	(*rl_SetParkingPosChanged := rl_SetParkingPos + rl_NewParkingPos;
	rl_NewParkingPos := real#0.0;*)
 
	if not x_CuttingPosOver then
	   (*x_MotorStartStckrDly := false;*)
	  	x_MotorStartDLY := true;
		(*rl_PrevCuttingPos := rl_SetCuttingPos;
		rl_NewCuttingPos := real#0.0;*)
		di_Main_distance := real_to_dint(rl_SetCuttingPos * rl_CountsPerDeg); (*first Cutting position*)
