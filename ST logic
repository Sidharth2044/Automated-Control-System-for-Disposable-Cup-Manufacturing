		(*diff_pos := rl_NewClampPos;*)
		(*rl_PrevParkingPos := rl_SetParkingPos;*)
		x_NewParkingPos := true;
	end_if;*)

	if not IX_Plug_LS and x_Init_ClampPosOver and x_NextCycleStart and x_ParkingPosDone then 
