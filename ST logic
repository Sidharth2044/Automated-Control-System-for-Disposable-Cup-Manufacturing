(*di_Total_Production := SEL_DINT ((x_Total_Prod_Reset OR x_Total_Prod_AutoReset), di_Total_Production, DINT#0);*)

(**************** Shift Production Calculation ****************)

TON_Shift_Prod_Timer(IN:=not TON_Shift_Prod_Timer.Q,PT:=t#28800s);
(* BOOL :=TON_Shift_Prod_Timer.Q;*)
t_Shift_Prod_TimerET:=TON_Shift_Prod_Timer.ET;

if TON_Shift_Prod_Timer.Q then
	di_Shift_Production := di_Total_Production;
end_if;

x_Shift_Prod_AutoReset := (di_Shift_Production > dint#2000000000);

(*di_Shift_Production := SEL_DINT((x_Shift_Prod_Reset OR x_Shift_Prod_AutoReset), di_Shift_Production, DINT#0);*)

(**************** Balance Production Calculation ****************)

if (*x_AutoCycle_On and*) (di_Target_Production > di_Total_Production) then
	di_Balance_Production := (di_Target_Production - di_Total_Production);
else
	di_Balance_Production := dint#0;
end_if;

(**************** Target Production Complete Alarm ****************)

if (di_Total_Production >= di_Target_Production) then
	x_Target_Prod_Achieved := true;
else
	x_Target_Prod_Achieved := false;
end_if;

TP_Buzzer1(IN:=x_Target_Prod_Achieved,PT:=t#5s);
QX_Buzzer1 := TP_Buzzer1.Q;

(* TIME :=TP_Buzzer1.ET;*)

(**************** Machine Running Time Calculation ****************)

TON_Second_Timer(IN:=(x_AutoCycle_On and not TON_Second_Timer.Q),PT:=t#1s);
(* BOOL :=TON_Second_Timer.Q;*)
(* TIME :=TON_Second_Timer.ET;*)

CTU_Second_Time(CU:=TON_Second_Timer.Q,RESET:=CTU_Second_Time.Q,PV:=60);
(* BOOL :=CTU_Second_Time.Q;*)
i_Second_Time:=CTU_Second_Time.CV;

CTU_Minute_Time(CU:=CTU_Second_Time.Q,RESET:=CTU_Minute_Time.Q,PV:=60);
(* BOOL :=CTU_Minute_Time.Q;*)
i_Minute_Time:=CTU_Minute_Time.CV;

CTU_Hour_Time(CU:=CTU_Minute_Time.Q,RESET:=CTU_Hour_Time.Q,PV:=9999);
(* BOOL :=CTU_Hour_Time.Q;*)
i_Hour_Time:=CTU_Hour_Time.CV;

end_if;

