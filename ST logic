		x_Cycle_Time := true;
		x_ParkingPosOver := true;
		rl_PrevClampPos := rl_SetClampPos;
		rl_PrevCuttingPos := rl_SetCuttingPos;
		rl_PrevParkingPos := rl_SetParkingPos;
		(*rl_NewClampPos := real#0.0;*)
		di_Main_distance := real_To_dint((*(real#360.0 + rl_NewClampPos)*)(rl_SetCuttingPosChanged (*+ rl_NewCuttingPos*) - rl_SetParkingPosChanged (*+ rl_NewParkingPos*))(* + rl_NewCuttingPos)*) * rl_CountsPerDeg);
		(*x_StartIndexDLY := true;*)
		x_MainPosStartFlexi := true;
      (*if x_NewClampPos then
		new_pos := di_Main_distance;
		end_if;*)
		x_NewClampPos := false;
		x_NewCuttingPos := false;
		x_NewParkingPos := false;
		x_NextCycleStart := false;
		rl_SetParkingPosChanged := rl_SetParkingPos + rl_NewParkingPos;
		rl_NewParkingPos := real#0.0;
		(*rl_NewCuttingPos := real#0.0;*)
		i_op_mode := 640;
	 end_if;

	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;		
		i_op_mode := 300;	
	end_if;

	x_PiercingHeater_OnOff := x_PiercingHeater_OnOff;
		
640:
	  		
	if (not IX_Index_LS and (*(x_IndexComplete or x_IndexLengthComplete) and (x_MainPosComplete or x_MainPosDone)*)(x_MainPosStart or x_MainPosStartFlexi) (*and (x_IndexOver or not x_NextCycleStart )*))then
		x_PlugDownDLY := true;
   	i_op_mode := 650;
	end_if;
	
	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;		
		i_op_mode := 300;
	end_if;			
	(*x_NextCycleStart := false;*)

650:
	if T_PlugDownDly.Q and (x_IndexComplete or x_IndexLengthComplete) and (x_MainPosComplete or x_MainPosDone) then
		x_IndexLengthComplete := false;
		x_IndexComplete := false;
		x_MainPosComplete:= false;
		x_MainPosStartFlexi := false;
		x_FormingDly := true;
		x_VaccumDly := true;	
		(*	x_NextCycleStart := false; *)
		x_CuttingPosOver := true;
		i_op_mode := 660;
	end_if;
	
	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;		
		i_op_mode := 300;
	end_if;		

660:

	(*di_Main_distance := real_to_dint((rl_SetClampPosChanged + rl_NewClampPos - rl_SetCuttingPosChanged + rl_NewCuttingPos) * rl_CountsPerDeg);*)

	if T_PlugDownDly.Q and (*not TP_PlugDownTime.Q and*) IX_Plug_LS then
		(*di_Main_distance := real_to_dint((rl_SetClampPos - rl_SetCuttingPos) * rl_CountsPerDeg);*)
		di_Main_distance := real_to_dint((rl_SetClampPosChanged (*+ rl_NewClampPos*) - rl_SetCuttingPosChanged (*+ rl_NewCuttingPos*)) * rl_CountsPerDeg);
		x_MainPosStartFlexi := true;
		x_StartIndexDLY := true;
		(*x_EjectionDlyTime := true;
		x_ScrapWDlyTime := true;*)
		x_PlugDownDLY := false;
		i_op_mode := 670;
	end_if;
	
	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;		
		i_op_mode := 300;
	end_if;		

670:
	if x_MainPosStartFlexi and (*not TP_PlugDownTime.Q and*) x_MainPosDone then
		x_MainPosStartFlexi := false;
		x_Init_ClampPosOver := true;
		di_Main_distance_Parking := real_to_dint((rl_SetClampPosChanged (*+ rl_NewClampPos*) - rl_SetParkingPosChanged (*+ rl_NewParkingPos*)) * rl_CountsPerDeg);
		x_ParkingPositionStart := true;
		x_EjectionDlyTime := true;
		x_ScrapWDlyTime := true;
		x_UnwinderDly := true;
		i_op_mode := 680;
	end_if;
	
	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;		
		i_op_mode := 300;
	end_if;		

680:

	ud_Index_AutoSpeed := dint_to_udint((int_to_dint(i_Index_AutoSpeed) * dint#65536) / dint#60000);
	di_IndexDistance := real_to_dint(rl_CountsPerMM * rl_Index_Length);

	if T_EjectionDlyTime.Q then
		(*x_StartIndexDLY := true;*) 
		x_EjectionDlyTime := false;
		x_NextCycleStart := true;
		x_Cycle_Time := false;
		i_op_mode := 630;
	end_if;

	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;		
		i_op_mode := 300;
	end_if;

(************* Auto Mode Operation (Stacker Mode) ************)

700:
	if ((IX_Cycle_Start or x_Cycle_Start_HMI) and not x_InitIndexing_over(*and(IX_Home_LS and IX_Plug_LS)*)) then
	   x_HomingDone := false;
		x_MotorStartDLY := false;
		x_Cycle_Start_Dly := true;
		x_AutoCycle_On := true;
		x_Cycle_Time := true;
		(*x_Init_Index_Start := true;*)
		(*i_IndexAct_Cnt:= 0;*)
		(*x_InitIndexing_over := false;*)
		i_op_mode := 710;
	end_if;

	if ((IX_Cycle_Start or x_Cycle_Start_HMI) and x_InitIndexing_over(*and(IX_Home_LS and IX_Plug_LS)*)) then
		x_HomingDone := false;
		x_MotorStartDLY := false;
		x_StartIndexDLY := true;
		x_AutoCycle_On := true;
		x_Cycle_Time := true;
		(*x_Init_Index_Start := true;*)
		(*i_IndexAct_Cnt:= 0;*)
		(*x_InitIndexing_over := false;*)
   end_if;

	if x_IndexOver and x_AutoCycle_On then
		i_op_mode := 730;
   end_if;

	if x_Clamp_Mode then
		i_op_mode := 500;
	end_if;

	if x_Flexi_Mode then
		i_op_mode := 600;
	end_if;

	x_PiercingHeater_OnOff := x_PiercingHeater_OnOff;

710:
	if TON_CycleStartDly.Q then
		x_StartIndexDLY := true;
		di_IndexDistance := real_to_dint(rl_CountsPerMM * rl_Index_Length);
		ud_Index_AutoSpeed := dint_to_udint((int_to_dint(i_Index_AutoSpeed) * dint#65536) / dint#60000);
      (*ud_Index_AutoSpeed := int_to_udint(i_Index_AutoSpeed);*)
		i_op_mode := 720;
	end_if;

720:
	if x_IndexOver then
		x_IndexStart := false;
		x_StartIndexDLY := false;
		i_IndexAct_Cnt := i_IndexAct_Cnt + 1;
	end_if;

	if i_IndexAct_Cnt = i_IndexSet_Cnt then 
		x_InitIndexing_over := true;
		x_IndexLengthComplete := true;
	   i_op_mode := 730;
	  else;
		i_op_mode := 710;
	end_if;

730:

	ud_Main_Speed := dint_to_udint((int_to_dint(i_Main_AutoSpeed) * dint#65536) / dint#60000);

	if not x_Init_ClampPosOver then
	   x_MotorStartStckrDly := false;
	  	x_MotorStartDLY := true;
		rl_PrevClampPos := rl_SetClampPos;
		rl_NewClampPos := real#0.0;
		di_Main_distance := real_to_dint(rl_SetClampPos * rl_CountsPerDeg); (*first clamp position*)
      (*ud_Main_Speed := dint_to_udint((int_to_dint(i_Main_AutoSpeed) * dint#65536) / dint#6000);*)
		x_MainPosCompleteStckr := false;
		x_NextCycleStart := false; 
		i_op_mode := 740;
	end_if;

	if x_Init_ClampPosOver and rl_PrevClampPos <> rl_SetClampPos and not x_NewClampPos then
		rl_NewClampPos := (rl_SetClampPos - rl_PrevClampPos);
		(*diff_pos := rl_NewClampPos;*)
		rl_PrevClampPos := rl_SetClampPos;
		x_NewClampPos := true;
	end_if;

	if not IX_Plug_LS and x_Init_ClampPosOver and x_NextCycleStart and x_MainPosCompleteStckr then
		x_Cycle_Time := true;
	   di_Main_distance := real_To_dint((*(real#360.0 + rl_NewClampPos)*) rl_SetClampPos * rl_CountsPerDeg);
		x_StartIndexDLY := true;
		x_MotorStartDLY := true;
		x_MainPosCompleteStckr := false; 
		rl_NewClampPos := real#0.0;
      (*if x_NewClampPos then
		new_pos := di_Main_distance;
		end_if;*)
		x_NewClampPos := false;
		x_NextCycleStart := false;
		i_op_mode := 740;
	 end_if;

	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;	
		i_op_mode := 300;	
	end_if;

	x_PiercingHeater_OnOff := x_PiercingHeater_OnOff;
		
740:	  		
	if (not IX_Index_LS and (*(x_IndexComplete or x_IndexLengthComplete) and x_MainPosComplete*)x_MainPosStart) (*and (x_IndexOver or not x_NextCycleStart )*)then
		x_PlugDownDLY := true;
   	i_op_mode := 750;
	end_if;
	
	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false; 
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;	
		i_op_mode := 300;
	end_if;			
		(*x_NextCycleStart := false;*)

750:
	if T_PlugDownDly.Q and (x_IndexComplete or x_IndexLengthComplete) and x_MainPosComplete then
		x_IndexLengthComplete := false;
		x_IndexComplete := false;
		x_MainPosComplete:= false;
		x_FormingDly := true;
		x_VaccumDly := true;	
		(*	x_NextCycleStart := false; *)
		x_Init_ClampPosOver := true;
		i_op_mode := 760;
	end_if;
	
	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;	
		i_op_mode := 300;
	end_if;		

760:
	if T_PlugDownDly.Q and (*not TP_PlugDownTime.Q and*) IX_Plug_LS then
		di_Main_distance := real_to_dint((real#360.0 - rl_PrevClampPos) * rl_CountsPerDeg);
		x_MotorStartStckrDly := true;
		x_EjectionDlyTime := true;
		x_ScrapWDlyTime := true;
		x_UnwinderDly := true;
		x_PlugDownDLY := false;
		i_op_mode := 770;
	end_if;
	
	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;
		i_IndexAct_Cnt := int#0;	
		i_op_mode := 300;
	end_if;		

770:

	ud_Index_AutoSpeed := dint_to_udint((int_to_dint(i_Index_AutoSpeed) * dint#65536) / dint#60000);
	di_IndexDistance := real_to_dint(rl_CountsPerMM * rl_Index_Length);

	if T_EjectionDlyTime.Q then
		(*x_StartIndexDLY := true;*) 
		x_EjectionDlyTime := false;
		x_NextCycleStart := true;
		x_Cycle_Time := false;
		i_op_mode := 730;
	end_if;

	if (IX_Cycle_Stop or x_Cycle_Stop_HMI) and x_AutoCycle_On then
		x_HomingAtStop := true;
		x_AutoCycle_On := false;
		x_Cycle_Start_Dly := false;
		x_InitIndexing_over := false;
		x_Cycle_Time := false;	
		i_IndexAct_Cnt := int#0;
		i_op_mode := 300;
	end_if;

end_case;

